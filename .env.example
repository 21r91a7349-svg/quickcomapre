# QuickCompare Production Environment Variables
# Copy this file to .env and fill in the values for deployment.

# ==============================================================================
# Database Configuration
# ==============================================================================
# The PostgreSQL connection URL (e.g. from Supabase or Neon).
# IMPORTANT: In production on Serverless platforms (Render, Vercel), you must use
# connection pooling (PgBouncer). 
# For Supabase, change port to 6543 and append ?pgbouncer=true
# Example: postgresql://postgres:password@db.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# ==============================================================================
# Authentication (Auth.js / NextAuth)
# ==============================================================================
# The canonical URL of the deployed application (required in production).
# Example: https://quickcompare.onrender.com
NEXTAUTH_URL="http://localhost:3000"

# Must be set to true when deployed behind a reverse proxy (e.g., Render, Vercel).
NEXTAUTH_TRUST_HOST="true"

# A random 32-character string used to encrypt session tokens.
# Generate via: openssl rand -base64 32
AUTH_SECRET="generate_a_secure_secret_here"

# Google OAuth credentials.
# Generate from Google Cloud Console (https://console.cloud.google.com).
AUTH_GOOGLE_ID="your_google_oauth_client_id"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# ==============================================================================
# AI & Processing
# ==============================================================================
# Google Gemini API key for matching products via LLM heuristics.
GEMINI_API_KEY="your_gemini_api_key"
